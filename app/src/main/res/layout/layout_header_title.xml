<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/header_title_height">

    <!-- Guideline: Khớp 100% với trang chủ -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/header_margin_top" />

    <LinearLayout
        android:id="@+id/container_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_top">

        <!-- Dòng 1: Space (Khớp 20dp với dòng 'Tổng cộng' ở trang chủ) -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_sub_line_height" />

        <!-- Dòng 2: CỐ ĐỊNH CHIỀU CAO 40DP để khớp hoàn hảo giữa các Fragment -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <!-- Tiêu đề: Luôn nằm chính giữa -->
            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="Tiêu đề"
                android:textColor="@color/colorOnSurface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Nút Back: Căn giữa theo chiều dọc trong khung 40dp cố định -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/colorOnSurface" />
        </RelativeLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>